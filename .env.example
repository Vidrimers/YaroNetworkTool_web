# Yaro Network Tool Portal — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env!

PORT=3000

# VPS Management API
VPS_API_URL=http://127.0.0.1:333
VPS_API_KEY=your_vpn_api_key_here

# AdminUI (checkers, Xray management)
ADMINUI_URL=http://your_vps_ip:666
ADMINUI_JWT_SECRET=your_adminui_jwt_secret_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_admin_id

# JWT
JWT_SECRET=generate_with_node_e_console_log_require_crypto_random_bytes_32_toString_hex
